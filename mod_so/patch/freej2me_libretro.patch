+static const unsigned long g_supported_resolutions[][2] = {
+	{96,65}, {96,96}, {104,80}, {128,128}, {132,176},
+	{128,160}, {176,208}, {176,220}, {208,208},
+	{240,320}, {320,240}, {240,400}, {352,416},
+	{360,640}, {640,360}, {480,800}, {800,480},
+};
+#define NUM_SUPPORTED_RES (sizeof(g_supported_resolutions) / sizeof(g_supported_resolutions[0]))
+
+static bool parse_resolution_from_path(const char *path, unsigned long *w, unsigned long *h)
+{
+	if (!path || !path[0]) return false;
+	const char *p = path;
+	const char *best_start = NULL;
+	int best_w = 0, best_h = 0;
+	while (*p)
+	{
+		long parsed_w = 0;
+		const char *start = p;
+		while (*p >= '0' && *p <= '9') { parsed_w = parsed_w * 10 + (*p - '0'); p++; }
+		if (parsed_w <= 0 || parsed_w > 9999) { p = start + 1; continue; }
+		char sep = *p;
+		if (sep != 'x' && sep != 'X' && sep != '*') { p = start + 1; continue; }
+		p++;
+		long parsed_h = 0;
+		const char *num_start = p;
+		while (*p >= '0' && *p <= '9') { parsed_h = parsed_h * 10 + (*p - '0'); p++; }
+		if (parsed_h <= 0 || parsed_h > 9999) { p = num_start + 1; continue; }
+		const char *before = (start == path) ? start : start - 1;
+		if (before != start && *before != '/' && *before != '\\') { continue; }
+		if (*p != '\0' && *p != '/' && *p != '\\' && *p != '.') { continue; }
+		int i;
+		for (i = 0; i < (int)NUM_SUPPORTED_RES; i++)
+		{
+			if ((unsigned long)parsed_w == g_supported_resolutions[i][0] &&
+			    (unsigned long)parsed_h == g_supported_resolutions[i][1])
+			{
+				best_start = start;
+				best_w = (int)parsed_w;
+				best_h = (int)parsed_h;
+				break;
+			}
+		}
+	}
+	if (best_start) { *w = (unsigned long)best_w; *h = (unsigned long)best_h; return true; }
+	return false;
+}
+
+static bool write_temp_rom_from_info(const struct retro_game_info *info)
+{
+	const char *dir = NULL;
+	char savedir[PATH_MAX_LENGTH];
+	if (Environ(RETRO_ENVIRONMENT_GET_SAVE_DIRECTORY, &dir) && dir && dir[0])
+		strncpy(savedir, dir, sizeof(savedir) - 1);
+	else if (Environ(RETRO_ENVIRONMENT_GET_SYSTEM_DIRECTORY, &dir) && dir && dir[0])
+		strncpy(savedir, dir, sizeof(savedir) - 1);
+	else
+		strncpy(savedir, ".", sizeof(savedir) - 1);
+	savedir[sizeof(savedir) - 1] = '\0';
+	snprintf(g_temp_rom_path, sizeof(g_temp_rom_path), "%s/%s", savedir, "retro_j2me_tmp.jar");
+	remove(g_temp_rom_path);
+	FILE *fp = fopen(g_temp_rom_path, "wb");
+	if (!fp) return false;
+	if (info->data && info->size)
+	{
+		if (fwrite(info->data, 1, info->size, fp) != info->size)
+		{ fclose(fp); remove(g_temp_rom_path); return false; }
+	}
+	else if (info->path && info->path[0])
+	{
+		FILE *src = fopen(info->path, "rb");
+		if (!src) { fclose(fp); remove(g_temp_rom_path); return false; }
+		char buf[8192]; size_t n; bool ok = true;
+		while ((n = fread(buf, 1, sizeof(buf), src)) > 0)
+		{
+			if (fwrite(buf, 1, n, fp) != n) { ok = false; break; }
+		}
+		fclose(src);
+		if (!ok) { fclose(fp); remove(g_temp_rom_path); return false; }
+	}
+	else { fclose(fp); remove(g_temp_rom_path); return false; }
+	fclose(fp);
+	g_temp_rom_valid = true;
+	return true;
+}
