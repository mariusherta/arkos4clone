diff --git a/core/hw/naomi/naomi.cpp b/core/hw/naomi/naomi.cpp
index c923e3724..64ec6bd1d 100644
--- a/core/hw/naomi/naomi.cpp
+++ b/core/hw/naomi/naomi.cpp
@@ -700,6 +700,31 @@ void naomi_Serialize(Serializer& ser)
 }
 void naomi_Deserialize(Deserializer& deser)
 {
+	if (deser.version() >= Deserializer::V40)
+	{
+		// Newer Flycast stores Naomi board serial flash state even for DC.
+		for (int i = 0; i < 2; i++)
+		{
+			deser.skip(8);		// writeBuffer
+			deser.skip(6);		// bool state pins
+			deser.skip<int>();	// state
+			deser.skip<u8>();	// command
+			deser.skip<u8>();	// byteOffset
+			deser.skip<u8>();	// bit
+			deser.skip<u8>();	// shift
+		}
+		deser >> aw_maple_devs;
+		deser >> coin_chute_time;
+		deser >> aw_ram_test_skipped;
+		if (deser.version() >= Deserializer::V45)
+		{
+			deser.skip<int>();	// Naomi DMA scheduler tag
+			deser.skip<int>();	// Naomi DMA scheduler start
+			deser.skip<int>();	// Naomi DMA scheduler end
+		}
+		midiTxBufIndex = 0;
+		return;
+	}
 	if (deser.version() < Deserializer::V9_LIBRETRO)
 	{
 		deser.skip<u32>();		// naomi_updates
