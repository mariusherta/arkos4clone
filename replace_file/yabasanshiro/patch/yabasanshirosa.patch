     if (mFontNormal == -1 || mFontBold == -1 || mFontIcons == -1)
         throw std::runtime_error("Could not load fonts!");
+
+    // Load CJK font as fallback for Chinese/Japanese/Korean support
+    int cjkFont = -1;
+    char exe_path[1024] = {0};
+    char font_path[1024] = {0};
+    ssize_t len = readlink("/proc/self/exe", exe_path, sizeof(exe_path)-1);
+    if (len != -1) {
+        exe_path[len] = '\0';
+        char *dir = dirname(exe_path);
+        snprintf(font_path, sizeof(font_path), "%s/wqy-microhei.ttf", dir);
+    }
+    
+    if (font_path[0] != '\0') {
+        cjkFont = nvgCreateFont(ctx, "cjk", font_path);
+    }
+    
+    if (cjkFont != -1) {
+        nvgAddFallbackFont(ctx, "sans", "cjk");
+        nvgAddFallbackFont(ctx, "sans-bold", "cjk");
+    }
 }
 
 NAMESPACE_END(nanogui)
